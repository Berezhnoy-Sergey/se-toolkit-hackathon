# Simple .env for local testing without Docker
# Copy this to .env and modify as needed

# Database
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secure_password_2026

# Backend
LMS_API_KEY=taskflow_api_key_change_this

# LLM API (get from OpenRouter or use Qwen)
LLM_API_KEY=your_openrouter_or_qwen_api_key_here
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Nanobot
NANOBOT_ACCESS_KEY=nanobot_access_key_change_this
