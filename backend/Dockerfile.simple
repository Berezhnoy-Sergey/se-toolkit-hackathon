# Simple Dockerfile for TaskFlow backend
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application
COPY backend/src/ ./src/

# Expose port
EXPOSE 8000

# Run
CMD ["uvicorn", "src.lms_backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
